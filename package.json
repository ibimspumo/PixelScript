{
  "name": "@ibimspumo/pixelscript",
  "version": "0.1.6",
  "description": "A compact JavaScript library for programmable pixel art and animations.",
  "type": "module",
  "license": "MIT",
  "author": "timocorvinus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibimspumo/PixelScript.git"
  },
  "homepage": "https://github.com/ibimspumo/PixelScript#readme",
  "bugs": {
    "url": "https://github.com/ibimspumo/PixelScript/issues"
  },
  "keywords": [
    "pixel-art",
    "pixel",
    "animation",
    "canvas",
    "svg",
    "gif",
    "png",
    "web-component",
    "vite"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/pixelscript.min.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element/register.d.ts",
      "import": "./dist/element/register.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "dev": "vite",
    "build": "npm run clean && node ./scripts/build.mjs && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "readme:assets": "npm run build && node ./scripts/generate-readme-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "release:check": "npm run build && npm pack --dry-run"
  },
  "dependencies": {
    "fflate": "0.8.2",
    "gifenc": "1.0.3"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
